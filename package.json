{
  "name": "@tjsasakinpm/devflow",
  "version": "0.2.1",
  "description": "fool-resistant, evidence-driven, engineered-by-default: state-aware workflow harness for AI-assisted software development",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "devflow": "./dist/main.js"
  },
  "files": [
    "dist/",
    "templates/",
    "LICENSE",
    "README.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist/",
    "prepack": "npm run build"
  },
  "keywords": [
    "devflow",
    "workflow",
    "ai-assisted-development",
    "brownfield",
    "reverse-engineering",
    "specification",
    "orchestration",
    "engineering-governance",
    "definition-of-done",
    "adversarial-review",
    "claude-code",
    "cursor",
    "spec-driven-development"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tjsasakifln/devflow"
  },
  "bugs": {
    "url": "https://github.com/tjsasakifln/devflow/issues"
  },
  "homepage": "https://github.com/tjsasakifln/devflow#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.16.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.19.0",
    "rimraf": "^6.0.0"
  }
}
