# ============================================
# Devflow Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env with real credentials.
# ============================================

# ── LLM Providers ──
# At least one provider is required for AI-powered features
# (adversarial-review-ai, ai-init, eval-run).

# Anthropic API (Claude)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Runtime ──

# Node environment: development | production | test
NODE_ENV=development

# ── Logging (Story 2.5) ──
# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Log format: text | json (default: text)
# LOG_FORMAT=text

# Suppress non-error output: true | false
# LOG_QUIET=false

# Include ISO 8601 timestamps: true | false
# LOG_TIMESTAMPS=false

# Include caller file:line in output: true | false
# LOG_SOURCE=false
